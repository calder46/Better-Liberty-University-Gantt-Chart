package JavaFinalProject;

import java.io.IOException;
import java.io.InputStream;
import java.net.MalformedURLException;
import java.net.URL;
import java.util.ArrayList;
import java.util.Scanner;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

public class Information_Gatherer {

    // Precompiled regex patterns (performance improvement)
    private static final Pattern STRONG_TAG = Pattern.compile("<strong>.+?</strong>");
    private static final Pattern PREREQ_DIV = Pattern.compile("<div class=\"cou.+?Prerequisite.+?</div>");
    private static final Pattern COURSE_NAME = Pattern.compile("title=\"[A-Z]{4}..\\d{3}");
    private static final Pattern SUBLINK_PATTERN = Pattern.compile("\"/search/.+?\"");

    private static final ArrayList<Course> courses = new ArrayList<>();

    public static void main(String[] args) throws MalformedURLException, IOException {

        Scanner userInput = new Scanner(System.in);
        System.out.print("Please paste Liberty's URL for the course plan: ");

        String theURL = userInput.next();
        String mainPageHTML = loadURL(theURL);

        Matcher sublinkMatcher = SUBLINK_PATTERN.matcher(mainPageHTML);

        while (sublinkMatcher.find()) {

            String sublink = sublinkMatcher.group().replace("\"", "").strip();
            String fullURL = "https://catalog.liberty.edu/" + sublink;

            String coursePageHTML = loadURL(fullURL);
            processCoursePage(coursePageHTML);

            // Progress indicator
            System.out.printf("\nProgress: %.2f%%",
                    (float) sublinkMatcher.end() / mainPageHTML.length() * 100);
        }

        // Test course (unchanged)
        Course test = new Course("TEST 001", "5");
        test.addPrerequisite(courses.get(1));
        test.addPrerequisite(courses.get(10));
        courses.add(test);

        printAllCourses();
    }

    // -----------------------------
    //         CORE METHODS
    // -----------------------------

    private static void processCoursePage(String html) {

        int titleIndex = html.indexOf("<div class=\"cols noindent\">");
        if (titleIndex == -1) {
            System.out.println("No prerequisites found for this course.");
            return;
        }

        // Extract a reasonable chunk of HTML
        String titleBlock = html.substring(titleIndex, Math.min(titleIndex + 12048, html.length()));
        Matcher strongMatcher = STRONG_TAG.matcher(titleBlock);

        if (!strongMatcher.find()) return;

        // Extract course name
        String name = stripTags(strongMatcher.group());
        if (courseExists(name)) {
            skipTwoStrongTags(strongMatcher);
            return;
        }

        // Extract credit hours
        strongMatcher.find(); // skip name
        strongMatcher.find(); // credit hours
        String creditHours = strongMatcher.group().replaceAll("\\D", "");

        Course newCourse = new Course(name, creditHours);
        courses.add(newCourse);

        // Extract prerequisites
        Matcher prereqMatcher = PREREQ_DIV.matcher(html);
        if (prereqMatcher.find()) {
            Matcher courseMatcher = COURSE_NAME.matcher(prereqMatcher.group());
            while (courseMatcher.find()) {
                String prereqName = courseMatcher.group().substring(7);
                addOrLinkPrerequisite(prereqName);
            }
        }
    }

    private static void addOrLinkPrerequisite(String prereqName) {

        int index = findCourseIndex(prereqName);

        if (index != -1) {
            courses.getLast().addPrerequisite(courses.get(index));
        } else {
            // Insert new course BEFORE the current one
            courses.add(courses.size() - 1, new Course(prereqName));
        }
    }

    // -----------------------------
    //         UTILITIES
    // -----------------------------

    private static String loadURL(String urlString) throws IOException {
        URL url = new URL(urlString);
        InputStream is = url.openStream();

        StringBuilder sb = new StringBuilder();
        int c;
        while ((c = is.read()) != -1) {
            sb.append((char) c);
        }
        return sb.toString();
    }

    private static boolean courseExists(String name) {
        return courses.stream().anyMatch(c -> c.getName().equals(name));
    }

    private static int findCourseIndex(String name) {
        for (int i = 0; i < courses.size(); i++) {
            if (courses.get(i).getName().equals(name)) return i;
        }
        return -1;
    }

    private static void skipTwoStrongTags(Matcher m) {
        if (m.find()) m.find();
    }

    private static String stripTags(String strongTag) {
        return strongTag.substring(8, strongTag.length() - 9);
    }

    private static void printAllCourses() {
        for (Course c : courses) {
            System.out.print(c.getName());
            if (c.getHours() == 0) {
                System.out.print(", external.");
            } else {
                System.out.printf(", credit hours: %d", c.getHours());
            }
            System.out.println(c.getPrerequisites());
        }
    }
}
